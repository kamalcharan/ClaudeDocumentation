## 10. Validation Queries

```sql
-- Seed summary
SELECT 'category_masters' as layer, COUNT(*) as total, 
  COUNT(*) FILTER (WHERE is_seed) as seeded, COUNT(*) FILTER (WHERE NOT is_live) as in_test
FROM t_category_master WHERE tenant_id = $1
UNION ALL SELECT 'category_details', COUNT(*), COUNT(*) FILTER (WHERE is_seed), COUNT(*) FILTER (WHERE NOT is_live)
FROM t_category_details WHERE tenant_id = $1
UNION ALL SELECT 'catalog_categories', COUNT(*), 0, 0
FROM t_catalog_categories WHERE tenant_id = $1
UNION ALL SELECT 'resources', COUNT(*), COUNT(*) FILTER (WHERE is_seed), COUNT(*) FILTER (WHERE NOT is_live)
FROM t_category_resources_master WHERE tenant_id = $1
UNION ALL SELECT 'blocks', COUNT(*), COUNT(*) FILTER (WHERE is_seed), COUNT(*) FILTER (WHERE NOT is_live)
FROM cat_blocks WHERE tenant_id = $1
UNION ALL SELECT 'equipment', COUNT(*), 0, COUNT(*) FILTER (WHERE NOT is_live)
FROM t_tenant_asset_registry WHERE tenant_id = $1
UNION ALL SELECT 'event_statuses', COUNT(*), COUNT(*) FILTER (WHERE is_seed), 0
FROM m_event_status_config WHERE tenant_id = $1;

-- Seller: Block matrix by equipment category
SELECT category, COUNT(*) as blocks,
  COUNT(DISTINCT (tags->>2)) as services, COUNT(DISTINCT (tags->>3)) as equipment_types
FROM cat_blocks WHERE tenant_id = $1 AND is_seed = true
GROUP BY category ORDER BY blocks DESC;

-- Buyer: Equipment by domain
SELECT specifications->>'sub_category' as domain, COUNT(*) as items,
  COUNT(*) FILTER (WHERE criticality = 'critical') as critical
FROM t_tenant_asset_registry WHERE tenant_id = $1 AND resource_type_id = 'equipment'
GROUP BY specifications->>'sub_category' ORDER BY items DESC;
