**Step S3: Generate Block Matrix** (from `m_service_equipment_map`)

```sql
CREATE OR REPLACE FUNCTION seed_seller_blocks(p_tenant_id uuid, p_served_industries varchar[])
RETURNS integer AS $$
DECLARE
  v_map_row RECORD;
  v_equip_type text;
  v_equip_label text;
  v_block_type_id uuid;
  v_count integer := 0;
BEGIN
  FOR v_map_row IN
    SELECT sem.*
    FROM m_service_equipment_map sem
    WHERE sem.industry_id = ANY(p_served_industries)
    AND sem.is_active = true
    ORDER BY sem.industry_id, sem.equipment_category, sem.sort_order
  LOOP
    SELECT td.id INTO v_block_type_id
    FROM t_category_details td
    JOIN t_category_master tm ON td.category_id = tm.id
    WHERE tm.tenant_id = p_tenant_id 
    AND tm.category_name = 'cat_block_type'
    AND td.code = v_map_row.block_type
    LIMIT 1;

    FOR v_equip_type IN SELECT jsonb_array_elements_text(v_map_row.equipment_types)
    LOOP
      v_equip_label := initcap(replace(v_equip_type, '_', ' '));
      
      INSERT INTO cat_blocks (
        tenant_id, block_type_id, 
        name, display_name, description,
        category, config, hsn_sac_code,
        tags, is_active, is_live, is_seed, sequence_no
      )
      VALUES (
        p_tenant_id, v_block_type_id,
        v_equip_type || '_' || v_map_row.service_code,
        v_equip_label || ' - ' || v_map_row.service_name,
        v_map_row.service_name || ' for ' || v_equip_label,
        v_map_row.equipment_category,
        v_map_row.config_template,
        v_map_row.hsn_sac_code,
        jsonb_build_array(v_map_row.industry_id, v_map_row.equipment_category, v_map_row.service_code, v_equip_type),
        true, false, true, v_map_row.sort_order
      )
      ON CONFLICT DO NOTHING;
      
      v_count := v_count + 1;
    END LOOP;
  END LOOP;
  
  RETURN v_count;
END;
$$ LANGUAGE plpgsql;
```

**Step S4: Seed Client Asset Types** (from `m_catalog_resource_templates` → `t_client_asset_registry`)

```sql
INSERT INTO t_client_asset_registry (
  tenant_id, resource_type_id, name, code, description,
  criticality, status, condition,
  specifications, tags, is_active, is_live
)
SELECT
  $tenant_id, mrt.resource_type_id, mrt.name,
  lower(replace(mrt.name, ' ', '_')),
  mrt.description,
  COALESCE(mrt.default_attributes->>'criticality', 'medium'),
  'template', 'good',
  jsonb_build_object(
    'make_examples', mrt.default_attributes->'make_examples',
    'maintenance_schedule', mrt.default_attributes->>'maintenance_schedule',
    'typical_lifespan_years', mrt.default_attributes->'typical_lifespan_years',
    'typical_amc_pct', mrt.pricing_guidance->'typical_amc_percent_of_cost',
    'industry', mrt.industry_id, 'sub_category', mrt.sub_category
  ),
  jsonb_build_array(mrt.industry_id, mrt.resource_type_id, mrt.sub_category),
  true, false
FROM m_catalog_resource_templates mrt
WHERE mrt.industry_id = ANY($served_industries)
AND mrt.resource_type_id IN ('equipment', 'asset')
AND mrt.is_active = true
AND NOT EXISTS (
  SELECT 1 FROM t_client_asset_registry car
  WHERE car.tenant_id = $tenant_id AND car.code = lower(replace(mrt.name, ' ', '_'))
);
```

