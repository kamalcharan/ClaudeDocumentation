## 4. Seed Algorithm

### 4.1 Common Steps (Both Personas)

**Step A: Foundation — Copy Categories**

```sql
-- A1: Copy m_category_master → t_category_master
INSERT INTO t_category_master (tenant_id, category_name, display_name, icon_name, sequence_no, is_active, is_live, is_seed)
SELECT 
  $tenant_id, m.category_name, m.display_name, m.icon_name, m.sequence_no, true, false, true
FROM m_category_master m
WHERE m.is_active = true
AND NOT EXISTS (
  SELECT 1 FROM t_category_master t 
  WHERE t.tenant_id = $tenant_id AND t.category_name = m.category_name
);

-- A2: Copy m_category_details → t_category_details  
INSERT INTO t_category_details (tenant_id, category_id, code, display_name, icon, sequence_no, is_active, is_live, is_seed)
SELECT
  $tenant_id, tcm.id, md.code, md.display_name, md.icon, md.sequence_no, true, false, true
FROM m_category_details md
JOIN m_category_master mcm ON md.category_id = mcm.id
JOIN t_category_master tcm ON tcm.tenant_id = $tenant_id AND tcm.category_name = mcm.category_name
WHERE md.is_active = true
AND NOT EXISTS (
  SELECT 1 FROM t_category_details td 
  WHERE td.tenant_id = $tenant_id AND td.category_id = tcm.id AND td.code = md.code
);
```

**Step B: Industry Records**

```sql
-- B1: Record served industries
INSERT INTO t_tenant_served_industries (tenant_id, industry_id)
SELECT $tenant_id, unnest($target_industries::varchar[])
ON CONFLICT DO NOTHING;

-- B2: Copy to tenant scope
INSERT INTO t_catalog_industries (tenant_id, industry_code, name, icon, parent_industry_code, level, segment_type, is_active)
SELECT 
  $tenant_id, mi.id, mi.name, mi.icon, mi.parent_id, mi.level, mi.segment_type, true
FROM m_catalog_industries mi
WHERE mi.id = ANY($target_industries)
AND NOT EXISTS (
  SELECT 1 FROM t_catalog_industries ti 
  WHERE ti.tenant_id = $tenant_id AND ti.industry_code = mi.id
);
```

