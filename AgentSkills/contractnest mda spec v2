### 4.3 BUYER Path (`t_tenant_profiles.profile_type = 'buyer'`)

**Step B1: Seed Equipment + Facility Registry** (from `m_catalog_resource_templates` → `t_tenant_asset_registry`)

```sql
CREATE OR REPLACE FUNCTION seed_buyer_registry(p_tenant_id uuid, p_industry_id varchar)
RETURNS jsonb AS $$
DECLARE
  v_equip_count integer := 0;
  v_facility_count integer := 0;
  v_cross_count integer := 0;
BEGIN
  -- OWN INDUSTRY: Seed equipment
  INSERT INTO t_tenant_asset_registry (
    tenant_id, resource_type_id, name, code, description,
    criticality, status, condition, specifications, tags, is_active, is_live
  )
  SELECT
    p_tenant_id, 'equipment', mrt.name,
    lower(replace(mrt.name, ' ', '_')), mrt.description,
    COALESCE(
      CASE 
        WHEN (mrt.pricing_guidance->>'typical_amc_percent_of_cost')::numeric >= 8 THEN 'critical'
        WHEN (mrt.pricing_guidance->>'typical_amc_percent_of_cost')::numeric >= 5 THEN 'high'
        ELSE 'medium'
      END, 'medium'),
    'active', 'good',
    jsonb_build_object(
      'sub_category', mrt.sub_category,
      'make_examples', mrt.default_attributes->'make_examples',
      'maintenance_schedule', mrt.default_attributes->>'maintenance_schedule',
      'requires_calibration', mrt.default_attributes->'requires_calibration',
      'typical_lifespan_years', mrt.default_attributes->'typical_lifespan_years',
      'typical_amc_pct', mrt.pricing_guidance->'typical_amc_percent_of_cost',
      'suggested_monthly_rate', mrt.pricing_guidance->'suggested_monthly_rate'
    ),
    jsonb_build_array(p_industry_id, 'equipment', mrt.sub_category),
    true, false
  FROM m_catalog_resource_templates mrt
  WHERE mrt.industry_id = p_industry_id AND mrt.resource_type_id = 'equipment'
  AND mrt.is_active = true AND mrt.sub_category IS NOT NULL
  AND NOT EXISTS (
    SELECT 1 FROM t_tenant_asset_registry tar
    WHERE tar.tenant_id = p_tenant_id AND tar.code = lower(replace(mrt.name, ' ', '_'))
  );
  GET DIAGNOSTICS v_equip_count = ROW_COUNT;

  -- OWN INDUSTRY: Seed facilities/assets
  INSERT INTO t_tenant_asset_registry (
    tenant_id, resource_type_id, name, code, description,
    criticality, status, condition, specifications, tags, is_active, is_live
  )
  SELECT
    p_tenant_id, 'asset', mrt.name,
    lower(replace(mrt.name, ' ', '_')), mrt.description,
    'high', 'active', 'good',
    jsonb_build_object(
      'sub_category', mrt.sub_category,
      'typical_area_sqft', mrt.default_attributes->'typical_area_sqft',
      'capacity', mrt.default_attributes->'capacity'
    ),
    jsonb_build_array(p_industry_id, 'facility', mrt.sub_category),
    true, false
  FROM m_catalog_resource_templates mrt
  WHERE mrt.industry_id = p_industry_id AND mrt.resource_type_id = 'asset'
  AND mrt.is_active = true
  AND NOT EXISTS (
    SELECT 1 FROM t_tenant_asset_registry tar
    WHERE tar.tenant_id = p_tenant_id AND tar.code = lower(replace(mrt.name, ' ', '_'))
  );
  GET DIAGNOSTICS v_facility_count = ROW_COUNT;

  -- CROSS-DOMAIN: Every buyer needs facility_management equipment
  -- (Hospitals need DG Sets, Elevators, HVAC, Fire systems, etc.)
  INSERT INTO t_tenant_asset_registry (
    tenant_id, resource_type_id, name, code, description,
    criticality, status, condition, specifications, tags, is_active, is_live
  )
  SELECT
    p_tenant_id, 'equipment', mrt.name,
    lower(replace(mrt.name, ' ', '_')), mrt.description,
    COALESCE(
      CASE 
        WHEN (mrt.pricing_guidance->>'typical_amc_percent_of_cost')::numeric >= 8 THEN 'critical'
        WHEN (mrt.pricing_guidance->>'typical_amc_percent_of_cost')::numeric >= 5 THEN 'high'
        ELSE 'medium'
      END, 'medium'),
    'active', 'good',
    jsonb_build_object(
      'sub_category', mrt.sub_category,
      'source_industry', mrt.industry_id,
      'make_examples', mrt.default_attributes->'make_examples',
      'maintenance_schedule', mrt.default_attributes->>'maintenance_schedule',
      'typical_amc_pct', mrt.pricing_guidance->'typical_amc_percent_of_cost'
    ),
    jsonb_build_array(p_industry_id, 'cross_domain', mrt.industry_id, mrt.sub_category),
    true, false
  FROM m_catalog_resource_templates mrt
  WHERE mrt.industry_id = 'facility_management'
  AND mrt.resource_type_id = 'equipment'
  AND mrt.is_active = true AND mrt.sub_category IS NOT NULL
  AND NOT EXISTS (
    SELECT 1 FROM t_tenant_asset_registry tar
    WHERE tar.tenant_id = p_tenant_id AND tar.code = lower(replace(mrt.name, ' ', '_'))
  );
  GET DIAGNOSTICS v_cross_count = ROW_COUNT;

  RETURN jsonb_build_object(
    'equipment', v_equip_count, 
    'facilities', v_facility_count, 
    'cross_domain', v_cross_count
  );
END;
$$ LANGUAGE plpgsql;
```

**Step B2: Seed Vendor Categories + Procurement Categories**

```sql
-- Vendor industries the buyer will engage
INSERT INTO t_tenant_served_industries (tenant_id, industry_id)
SELECT $tenant_id, industry_id
FROM (VALUES ('facility_management'), ('technology')) AS v(industry_id)
WHERE NOT EXISTS (
  SELECT 1 FROM t_tenant_served_industries tsi
  WHERE tsi.tenant_id = $tenant_id AND tsi.industry_id = v.industry_id
);

-- Service categories for procurement (primary categories for their industry)
INSERT INTO t_catalog_categories (
  tenant_id, industry_id, category_code, name, description, icon,
  default_pricing_model, suggested_duration, common_variants,
  master_category_id, is_custom, is_active, sort_order
)
SELECT 
  $tenant_id, tci.id, mc.id,
  COALESCE(mcim.display_name, mc.name),
  mc.description, mc.icon,
  mc.default_pricing_model, mc.suggested_duration, mc.common_variants,
  mc.id, false, true, mcim.display_order
FROM m_catalog_category_industry_map mcim
JOIN m_catalog_categories mc ON mcim.category_id = mc.id
JOIN t_catalog_industries tci ON tci.tenant_id = $tenant_id AND tci.industry_code = mcim.industry_id
WHERE mcim.industry_id = $industry_id
AND mcim.is_primary = true
AND mcim.is_active = true AND mc.is_active = true
AND NOT EXISTS (
  SELECT 1 FROM t_catalog_categories tc 
  WHERE tc.tenant_id = $tenant_id AND tc.category_code = mc.id
);
